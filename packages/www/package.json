{
  "name": "@gregoryjscott/www",
  "version": "1.0.0",
  "description": "Manages gregoryjscott.com",
  "scripts": {
    "bootstrap": "gem install bundler jekyll && bundle update",
    "prep": "ts-node prep.ts",
    "hook": "ts-node hook.ts",
    "build": "bundle exec jekyll build",
    "www": "bundle exec jekyll serve",
    "open": "open http://127.0.0.1:4000",
    "deploy": "gh-pages --dist _site --src '**' --repo https://github.com/gregoryjscott/gregoryjscott.github.io.git --branch master --message 'Generated by me'"
  },
  "devDependencies": {
    "@types/node": "^18.11.9",
    "gh-pages": "^3.2.3",
    "ts-node": "10.9.1",
    "typescript": "4.9.3"
  },
  "dependencies": {
    "yaml": "^2.1.3"
  }
}
